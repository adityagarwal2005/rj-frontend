# Base URL of the Django backend API, including the /api prefix.
# Local dev (backend running via `python manage.py runserver`):
VITE_API_BASE_URL=http://localhost:8000/api

# Production (Render): set this to your deployed backend's URL, e.g.
# VITE_API_BASE_URL=https://rajwaditukda-backend.onrender.com/api
